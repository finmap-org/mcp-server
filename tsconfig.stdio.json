{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "target": "ESNext",
    "lib": ["ESNext"],
    "types": ["node"],
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/index.ts"]
}
